# Connect to PeakSoft's exposed MQTT broker (over secure WebSocket).
# These defaults point at the live demo broker. If the broker host ever
# changes, update MQTT_HOST (the current value is shown in the ngrok inspector).
MQTT_HOST=shrubs-dentist-submitter.ngrok-free.dev
MQTT_PORT=443
MQTT_TRANSPORT=websockets
MQTT_TLS=true
MQTT_USERNAME=iot_client
MQTT_PASSWORD=iot_password

# Which device IDs to simulate, and how fast each publishes (Hz).
SIM_DEVICES=dev-001,dev-002,dev-003
SIM_DEFAULT_RATE_HZ=1.0
