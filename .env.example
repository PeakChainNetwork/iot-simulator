# Connect to PeakSoft's exposed MQTT broker (over secure WebSocket).
# Get the host and credentials from PeakSoft.
MQTT_HOST=<broker-host>
MQTT_PORT=443
MQTT_TRANSPORT=websockets
MQTT_WS_PATH=/mqtt
MQTT_TLS=true
MQTT_USERNAME=iot_client
MQTT_PASSWORD=<password-from-peaksoft>

# Which device IDs to simulate, and how fast each publishes (Hz).
SIM_DEVICES=dev-001,dev-002,dev-003
SIM_DEFAULT_RATE_HZ=1.0
